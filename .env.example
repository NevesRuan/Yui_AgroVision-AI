# Ollama (LLM local)
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=30m

# Agente
AGENT_EVENT_LIMIT=12

# Camera / stream de video
CAMERA_SOURCE=https://wzmedia.dot.ca.gov/D11/C214_SB_5_at_Via_De_San_Ysidro.stream/playlist.m3u8
CAMERA_RECONNECT_SECONDS=5

# YOLO
MODEL_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.5
TARGET_CLASSES=person,car,truck,bus,motorcycle,bicycle
MIN_CONSECUTIVE_FRAMES=3
ALERT_COOLDOWN_SECONDS=15

# Persistencia
DB_PATH=detections.db
SAVE_DIR=static/captures

# Limites HTTP
MAX_REQUEST_BODY_BYTES=262144

# Debug
DEBUG=0

# Web scraping - clima (Open-Meteo, https://open-meteo.com/)
WEATHER_ENABLED=1
WEATHER_LATITUDE=32.55
WEATHER_LONGITUDE=-117.04
WEATHER_CACHE_TTL_SECONDS=600
WEATHER_REQUEST_TIMEOUT=5
